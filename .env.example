# Copy this file to `.env` and fill in real values for LOCAL development.
# On Streamlit Community Cloud, set these in the app's Settings → Secrets
# (TOML format) instead — do NOT commit a real .env.

# ── Required secrets ──
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# ── Optional tuning (defaults shown) ──
# MODEL_NAME=gpt-4o-mini
# TEMPERATURE=0.0
# LLM_TIMEOUT_S=60
# LLM_MAX_RETRIES=3
# SEARCH_MAX_RESULTS=5
# SCRAPE_TIMEOUT_S=8
# SCRAPE_MAX_CHARS=3000
# SCRAPE_MAX_BYTES=3000000
# SNIPPET_MAX_CHARS=300
# HANDOFF_MAX_CHARS=800
# MAX_TOPIC_CHARS=300
# LOG_LEVEL=INFO
