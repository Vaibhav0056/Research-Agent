# Streamlit secrets template.
#
# LOCAL: copy to `.streamlit/secrets.toml` (git-ignored) OR use a `.env` file.
# DEPLOYED (Streamlit Community Cloud): paste these keys into
#   App → Settings → Secrets  (this same TOML format).
#
# config.py reads st.secrets first, then falls back to environment variables.

OPENAI_API_KEY = "sk-..."
TAVILY_API_KEY = "tvly-..."

# Optional overrides:
# MODEL_NAME = "gpt-4o-mini"
# LOG_LEVEL = "INFO"
